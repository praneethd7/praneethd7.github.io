---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Praneeth Devunuri | GenAI Specialist & Research", 
  description = "Praneeth Devunuri's portfolio. Transitioning from PhD research in autonomous vehicles and reinforcement learning to professional Generative AI development."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col bg-slate-950 text-slate-100 selection:bg-teal-500/30 selection:text-teal-200 antialiased overflow-x-hidden font-inter">
    <!-- Glow Background Decorative Blobs -->
    <div class="fixed inset-0 -z-50 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -left-40 h-[600px] w-[600px] rounded-full bg-teal-500/5 blur-[120px]"></div>
      <div class="absolute top-1/3 right-0 h-[500px] w-[500px] rounded-full bg-indigo-500/5 blur-[120px]"></div>
      <div class="absolute -bottom-40 left-1/3 h-[600px] w-[600px] rounded-full bg-purple-500/5 blur-[120px]"></div>
    </div>

    <Header />
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <Footer />
  </body>
</html>
