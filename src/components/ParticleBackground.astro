<canvas id="particle-canvas" class="fixed inset-0 -z-40 pointer-events-none opacity-45 transition-opacity duration-1000"></canvas>

<script>
  // Math & AI Symbols to float in the background
  const symbols = ['ε', 'λ', 'θ', '∇', '∫', '∂', 'w', 'b', '0', '1', 'Σ', 'μ', 'σ', 'f(x)', 'dy/dx'];

  let animationId = null;
  let canvas = null;
  let ctx = null;
  let particles = [];
  const mouse = { x: null, y: null, active: false };

  class Particle {
    x = 0;
    y = 0;
    vx = 0;
    vy = 0;
    size = 0;
    color = '';
    isSymbol = false;
    symbol = '';
    opacity = 0;
    rotation = 0;
    rotationSpeed = 0;

    constructor(w, h) {
      this.reset(w, h, true);
    }

    reset(w, h, initial = false) {
      // Start randomly on screen, or just off-screen if resetting after moving off-screen
      if (initial) {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
      } else {
        // Place just outside boundaries
        const side = Math.floor(Math.random() * 4);
        if (side === 0) { // Top
          this.x = Math.random() * w;
          this.y = -20;
        } else if (side === 1) { // Right
          this.x = w + 20;
          this.y = Math.random() * h;
        } else if (side === 2) { // Bottom
          this.x = Math.random() * w;
          this.y = h + 20;
        } else { // Left
          this.x = -20;
          this.y = Math.random() * h;
        }
      }

      this.size = Math.random() * 1.5 + 1.2; // Tiny dots
      
      // Extremely slow drift speed
      this.vx = (Math.random() - 0.5) * 0.35;
      this.vy = (Math.random() - 0.5) * 0.35;
      
      // Select palette based on site brand theme (cyan, indigo, gold)
      const rand = Math.random();
      if (rand < 0.5) {
        this.color = '13, 255, 198'; // Brand Cyan (#0DFFC6)
      } else if (rand < 0.9) {
        this.color = '99, 102, 241'; // Brand Indigo (#6366F1)
      } else {
        this.color = '251, 191, 36'; // Brand Gold (#FBBF24)
      }

      // 25% chance of being a mathematical glyph
      this.isSymbol = Math.random() < 0.25;
      if (this.isSymbol) {
        this.symbol = symbols[Math.floor(Math.random() * symbols.length)];
        this.size = Math.random() * 4 + 9; // Readable but small glyph (9px to 13px)
        this.rotation = Math.random() * Math.PI * 2;
        this.rotationSpeed = (Math.random() - 0.5) * 0.005; // Slow rotation
      }
      
      this.opacity = Math.random() * 0.35 + 0.15; // Subtle opacity (15% to 50%)
    }

    update(w, h) {
      this.x += this.vx;
      this.y += this.vy;
      
      if (this.isSymbol) {
        this.rotation += this.rotationSpeed;
      }

      // Re-spawn if drifted too far off screen
      if (this.x < -30 || this.x > w + 30 || this.y < -30 || this.y > h + 30) {
        this.reset(w, h, false);
      }
    }

    draw(ctx) {
      ctx.save();
      if (this.isSymbol) {
        ctx.translate(this.x, this.y);
        ctx.rotate(this.rotation);
        ctx.font = `500 ${this.size}px "Outfit", system-ui, sans-serif`;
        ctx.fillStyle = `rgba(${this.color}, ${this.opacity})`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(this.symbol, 0, 0);
      } else {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${this.color}, ${this.opacity})`;
        ctx.shadowBlur = 3;
        ctx.shadowColor = `rgba(${this.color}, 0.3)`;
        ctx.fill();
      }
      ctx.restore();
    }
  }

  function resizeCanvas() {
    if (!canvas) return;
    const dpr = window.devicePixelRatio || 1;
    const width = window.innerWidth;
    const height = window.innerHeight;
    
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    
    if (ctx) {
      ctx.scale(dpr, dpr);
    }
  }

  function createParticles() {
    const w = window.innerWidth;
    const h = window.innerHeight;
    // Adapt particle count to resolution
    const particleCount = Math.max(18, Math.min(55, Math.floor((w * h) / 32000)));
    
    particles = [];
    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle(w, h));
    }
  }

  function drawConnections() {
    if (!ctx) return;
    const maxDist = 110;
    const maxDistSq = maxDist * maxDist;
    const len = particles.length;

    for (let i = 0; i < len; i++) {
      const p1 = particles[i];
      
      // Node-to-node connections (Constellation pattern)
      for (let j = i + 1; j < len; j++) {
        const p2 = particles[j];
        
        // Don't connect if both are symbols to keep layout clean
        if (p1.isSymbol && p2.isSymbol) continue;

        const dx = p1.x - p2.x;
        const dy = p1.y - p2.y;
        const distSq = dx * dx + dy * dy;
        
        if (distSq < maxDistSq) {
          const dist = Math.sqrt(distSq);
          const alpha = (1 - dist / maxDist) * 0.09;
          ctx.beginPath();
          ctx.moveTo(p1.x, p1.y);
          ctx.lineTo(p2.x, p2.y);
          
          // Interpolate stroke color slightly between Cyan/Indigo/Gold
          ctx.strokeStyle = `rgba(99, 102, 241, ${alpha})`; // Indigo base connection
          ctx.lineWidth = 0.55;
          ctx.stroke();
        }
      }

      // Mouse interactivity connections
      if (mouse.active && mouse.x !== null && mouse.y !== null) {
        const dx = p1.x - mouse.x;
        const dy = p1.y - mouse.y;
        const distSq = dx * dx + dy * dy;
        const mouseRadius = 160;
        
        if (distSq < mouseRadius * mouseRadius) {
          const dist = Math.sqrt(distSq);
          
          // Gentle attraction towards cursor
          const force = (mouseRadius - dist) / mouseRadius;
          const pull = force * 0.08;
          p1.vx -= (dx / dist) * pull * 0.15;
          p1.vy -= (dy / dist) * pull * 0.15;

          // Limit speed under influence of mouse
          const speed = Math.sqrt(p1.vx * p1.vx + p1.vy * p1.vy);
          const limit = p1.isSymbol ? 0.35 : 0.65;
          if (speed > limit) {
            p1.vx = (p1.vx / speed) * limit;
            p1.vy = (p1.vy / speed) * limit;
          }

          // Draw synapses line to cursor
          const alpha = (1 - dist / mouseRadius) * 0.13;
          ctx.beginPath();
          ctx.moveTo(p1.x, p1.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(13, 255, 198, ${alpha})`; // Cyan line
          ctx.lineWidth = 0.75;
          ctx.stroke();
        }
      }
    }
  }

  function handleMouseMove(e) {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
    mouse.active = true;
  }

  function handleMouseLeave() {
    mouse.active = false;
    mouse.x = null;
    mouse.y = null;
  }

  function animate() {
    if (!canvas || !ctx) return;
    
    ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
    
    const w = window.innerWidth;
    const h = window.innerHeight;

    particles.forEach(p => {
      p.update(w, h);
      p.draw(ctx);
    });

    drawConnections();

    animationId = requestAnimationFrame(animate);
  }

  function start() {
    canvas = document.getElementById('particle-canvas');
    if (!canvas) return;
    ctx = canvas.getContext('2d');
    if (!ctx) return;

    resizeCanvas();
    createParticles();
    
    window.addEventListener('resize', resizeCanvas);
    window.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('mouseleave', handleMouseLeave);
    
    animate();
  }

  function stop() {
    if (animationId) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }
    window.removeEventListener('resize', resizeCanvas);
    window.removeEventListener('mousemove', handleMouseMove);
    window.removeEventListener('mouseleave', handleMouseLeave);
    particles = [];
  }

  // Initial Run
  start();

  // Astro Page Transitions lifecycle hook support
  document.addEventListener('astro:after-swap', () => {
    stop();
    start();
  });

  document.addEventListener('astro:before-swap', () => {
    stop();
  });
</script>
