---
const currentPath = Astro.url.pathname;
const navItems = [
  { name: 'Home', path: '/' },
  { name: 'Projects', path: '/projects' },
  { name: 'Publications', path: '/publications' },
  { name: 'Photography', path: '/photography' },
  { name: 'Activities', path: '/activities' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-white/10 bg-slate-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <a href="/" class="group flex items-center gap-1.5 font-outfit text-xl font-bold tracking-wider text-slate-100">
        <span class="text-teal-400 font-mono transition-transform duration-300 group-hover:rotate-12">ε</span>
        <span class="bg-gradient-to-r from-slate-100 to-slate-400 bg-clip-text text-transparent group-hover:from-teal-400 group-hover:to-indigo-400 transition-all duration-300">
          Devunuri
        </span>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => {
        // Handle active state matching root and subpaths
        const isActive = item.path === '/' 
          ? currentPath === '/' 
          : currentPath.startsWith(item.path);
        return (
          <a
            href={item.path}
            class={`relative py-1 font-inter text-sm font-medium tracking-wide transition-colors duration-300 hover:text-teal-300 ${
              isActive ? 'text-teal-400 font-semibold' : 'text-slate-400'
            }`}
          >
            {item.name}
            {isActive && (
              <span class="absolute bottom-0 left-0 h-[2px] w-full rounded-full bg-gradient-to-r from-teal-400 to-indigo-500" />
            )}
          </a>
        );
      })}
      
      <a
        href="mailto:devunurisaipraneeth@gmail.com"
        class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-teal-500 to-indigo-600 px-4.5 py-1.5 font-outfit text-xs font-semibold text-white shadow-lg shadow-teal-500/10 hover:shadow-indigo-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
      >
        Hire Me
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 text-slate-400 hover:bg-white/5 hover:text-slate-100 md:hidden transition-colors"
      aria-label="Toggle Menu"
    >
      <svg
        id="menu-icon"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg
        id="close-icon"
        class="hidden h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-drawer"
    class="hidden fixed inset-x-0 top-16 z-40 border-b border-white/10 bg-slate-950/95 backdrop-blur-lg px-4 py-6 md:hidden transition-all duration-300"
  >
    <div class="flex flex-col gap-4">
      {navItems.map((item) => {
        const isActive = item.path === '/' 
          ? currentPath === '/' 
          : currentPath.startsWith(item.path);
        return (
          <a
            href={item.path}
            class={`flex py-2 px-4 rounded-lg font-inter text-base font-medium transition-colors ${
              isActive 
                ? 'bg-teal-500/10 text-teal-400 font-semibold' 
                : 'text-slate-400 hover:bg-white/5 hover:text-slate-200'
            }`}
          >
            {item.name}
          </a>
        );
      })}
      
      <a
        href="mailto:devunurisaipraneeth@gmail.com"
        class="mt-4 flex w-full items-center justify-center rounded-lg bg-gradient-to-r from-teal-500 to-indigo-600 py-3 font-outfit text-sm font-semibold text-white shadow-lg"
      >
        Email Me
      </a>
    </div>
  </div>
</header>

<script>
  function setupDrawer() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (toggle && drawer && menuIcon && closeIcon) {
      toggle.addEventListener('click', () => {
        const isHidden = drawer.classList.contains('hidden');
        if (isHidden) {
          drawer.classList.remove('hidden');
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
        } else {
          drawer.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        }
      });
    }
  }

  // Run on load and after View Transitions
  setupDrawer();
  document.addEventListener('astro:after-swap', setupDrawer);
</script>
