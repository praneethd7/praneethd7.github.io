---

<footer class="w-full border-t border-white/10 bg-slate-950/90 py-12 text-slate-400">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 border-b border-white/5 pb-8">
      <div class="flex flex-col items-center md:items-start gap-1">
        <div class="flex items-center gap-1.5 font-outfit text-lg font-bold text-slate-200">
          <span class="text-teal-400 font-mono">ε</span>
          <span>Praneeth Devunuri</span>
        </div>
        <p class="text-xs text-slate-500 text-center md:text-left max-w-sm mt-1">
          GenAI Specialist. Bridging autonomous systems, machine learning models, and optimization systems.
        </p>
      </div>

      <div class="flex gap-4">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-slate-400 hover:border-teal-400 hover:text-teal-400 hover:bg-teal-500/5 transition-all duration-300"
            aria-label={social.name}
            set:html={social.svg}
          />
        ))}
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 text-xs text-slate-500">
      <p>&copy; {currentYear} Praneeth Devunuri. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
        <a href="/publications" class="hover:text-slate-300 transition-colors">Publications</a>
        <a href="/projects" class="hover:text-slate-300 transition-colors">Projects</a>
        <a href="/photography" class="hover:text-slate-300 transition-colors">Photography</a>
        <a href="/activities" class="hover:text-slate-300 transition-colors">Activities</a>
      </div>
    </div>
  </div>
</footer>
