---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const activities = await getCollection('activities');
activities.sort((a, b) => a.data.order - b.data.order);

const activitiesWithContent = await Promise.all(
  activities.map(async (activity) => {
    const { Content } = await render(activity);
    return { activity, Content };
  })
);

const grouped = {
  responsibility: {
    title: 'Positions of Responsibility',
    icon: `<svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    items: activitiesWithContent.filter(a => a.activity.data.type === 'responsibility')
  },
  competition: {
    title: 'Competitions & Mentoring',
    icon: `<svg class="h-6 w-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
    items: activitiesWithContent.filter(a => a.activity.data.type === 'competition')
  },
  design: {
    title: 'Design & Creative Work',
    icon: `<svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
    items: activitiesWithContent.filter(a => a.activity.data.type === 'design')
  },
  hobby: {
    title: 'Hobbies & Recreation',
    icon: `<svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    items: activitiesWithContent.filter(a => a.activity.data.type === 'hobby')
  }
};
---

<Layout title="Activities & Hobbies | Praneeth Devunuri" description="Praneeth Devunuri's leadership responsibilities, academic competitions, and creative design hobbies including drone flying, drawings, cycling, and trekking.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Praneeth Devunuri's Activities and Positions of Responsibility",
      "description": "Leadership responsibilities, academic competitions, and creative design hobbies.",
      "itemListElement": activities.map((act, idx) => ({
        "@type": "ListItem",
        "position": idx + 1,
        "item": {
          "@type": "CreativeWork",
          "name": act.data.title,
          "genre": act.data.type,
          "roleName": act.data.role || undefined
        }
      }))
    })} />
  </Fragment>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    
    <!-- Title Area -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="font-outfit text-4xl sm:text-5xl font-extrabold tracking-tight text-white">
        Activities & Leadership
      </h1>
      <p class="font-inter text-slate-400 mt-4 leading-relaxed">
        Beyond code and research: my leadership roles, competition records, graphic design, and recreational hobbies.
      </p>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- Sidebar Navigation (Sticky) -->
      <nav class="hidden lg:block lg:col-span-3 sticky top-24 self-start space-y-2">
        {Object.entries(grouped).map(([key, group]) => (
          <a
            href={`#${key}`}
            class="flex items-center gap-3 px-4 py-3 rounded-xl font-outfit text-sm font-semibold text-slate-400 hover:text-slate-200 hover:bg-white/5 transition-all duration-300 border border-transparent hover:border-white/5"
          >
            <div class="shrink-0" set:html={group.icon} />
            <span>{group.title}</span>
          </a>
        ))}
      </nav>

      <!-- Main Contents (9 cols) -->
      <div class="lg:col-span-9 space-y-16">
        {Object.entries(grouped).map(([key, group]) => {
          if (group.items.length === 0) return null;
          return (
            <section id={key} class="scroll-mt-24">
              <div class="flex items-center gap-3 border-b border-white/10 pb-4 mb-8">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-900 border border-white/10" set:html={group.icon} />
                <h2 class="font-outfit text-2xl font-extrabold text-white tracking-tight">{group.title}</h2>
              </div>

              <div class="space-y-10">
                {group.items.map(({ activity, Content }) => (
                  <div class="rounded-2xl border border-white/5 bg-slate-900/10 p-6 sm:p-8 backdrop-blur-sm hover:border-white/10 transition-colors">
                    <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
                      <h3 class="font-outfit text-xl font-bold text-slate-100">{activity.data.title}</h3>
                      {activity.data.role && (
                        <span class="rounded-full bg-white/5 border border-white/10 px-3 py-0.5 text-xs font-semibold text-slate-300">
                          {activity.data.role}
                        </span>
                      )}
                    </div>
                    
                    <article class="prose prose-invert max-w-none text-slate-300 text-sm sm:text-base leading-relaxed space-y-4">
                      <Content />
                    </article>
                  </div>
                ))}
              </div>
            </section>
          );
        })}
      </div>

    </div>

  </div>
</Layout>
