---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const featuredProjects = await getCollection('projects', ({ data }) => data.featured);
featuredProjects.sort((a, b) => a.data.order - b.data.order);

const skills = [
  {
    category: 'Generative AI & LLMs',
    icon: `<svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
    items: ['Agentic Workflows (crewAI, LangGraph)', 'Hybrid RAG & Semantic Search', 'LLM Fine-tuning (LoRA, PEFT)', 'Inference Optimization (vLLM)']
  },
  {
    category: 'Reinforcement Learning',
    icon: `<svg class="h-6 w-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    items: ['Q-Learning & Policy Gradients', 'Autonomous Control Algorithms', 'Simulation Modeling (SUMO, VISSIM)', 'Decision Processes (MDPs)']
  },
  {
    category: 'Computer Vision',
    icon: `<svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>`,
    items: ['Object Detection & Tracking (YOLO)', 'Image Processing (OpenCV)', 'Spatial-CNN (Lane Line Prediction)', 'Sensor Fusion (Drones & Vehicles)']
  }
];

const timeline = [
  {
    period: '2025 - Present',
    title: 'Senior AI Scientist',
    institution: 'Optym',
    description: 'Developing and deploying state-of-the-art machine learning models, optimization algorithms, and Generative AI (LLM) workflows to solve complex logistics and transportation scheduling challenges.',
    logo: '/assets/logo_optym.png'
  },
  {
    period: '2020 - 2025',
    title: 'Ph.D. Researcher & Doctoral Student',
    institution: 'University of Illinois Urbana-Champaign',
    description: 'Researched intelligent transportation systems, reinforcement learning for signal controls, and Large Language Model (LLM) frameworks for transit data under Dr. Lewis Lehe. Graduated in 2025.',
    logo: '/assets/logo_uiuc.svg'
  },
  {
    period: '2018 - 2020',
    title: 'Graduate Assistant Researcher',
    institution: 'Texas A&M University',
    description: 'Built autonomous ride-sharing simulations, modeled pricing schemes for Mobility-as-a-Service, and performed emergency vehicle response experiments.',
    logo: '/assets/logo_tamu.svg'
  },
  {
    period: '2014 - 2018',
    title: 'Bachelor of Technology',
    institution: 'Indian Institute of Technology, Madras',
    description: 'Developed image processing frameworks for traffic extraction, created glass fragmentation test prototypes, and served as Webops Head.',
    logo: '/assets/logo_iitm.svg'
  }
];
---

<Layout title="Praneeth Devunuri | GenAI & Autonomous Systems Engineer">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://praneethd7.github.io/#person",
        "name": "Saipraneeth Devunuri",
        "alternateName": ["Praneeth Devunuri", "Sai Praneeth Devunuri", "S. Devunuri"],
        "url": "https://praneethd7.github.io",
        "image": "https://praneethd7.github.io/assets/pro_pic_new.jpg",
        "description": "Senior AI Scientist at Optym. Transitioned from Ph.D. research in Connected and Autonomous Vehicles (UIUC) to driving next-generation AI and optimization systems.",
        "jobTitle": "Senior AI Scientist",
        "worksFor": {
          "@type": "Corporation",
          "name": "Optym",
          "url": "https://optym.com"
        },
        "alumniOf": [
          {
            "@type": "EducationalOrganization",
            "name": "University of Illinois Urbana-Champaign",
            "url": "https://illinois.edu"
          },
          {
            "@type": "EducationalOrganization",
            "name": "Texas A&M University",
            "url": "https://tamu.edu"
          },
          {
            "@type": "EducationalOrganization",
            "name": "Indian Institute of Technology, Madras",
            "url": "https://www.iitm.ac.in"
          }
        ],
        "knowsAbout": [
          "Generative AI",
          "Large Language Models (LLMs)",
          "Agentic Workflows",
          "Retrieval-Augmented Generation (RAG)",
          "Reinforcement Learning",
          "Autonomous Vehicles",
          "Connected and Autonomous Vehicles",
          "Intelligent Transportation Systems",
          "Computer Vision",
          "Optimization Algorithms"
        ],
        "sameAs": [
          "https://github.com/praneethd7",
          "https://linkedin.com/in/praneethd7",
          "https://scholar.google.com/citations?user=z2Z271UAAAAJ&hl=en",
          "https://x.com/praneethDevunu1",
          "https://facebook.com/praneethDevunuri"
        ]
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://praneethd7.github.io/#website",
        "url": "https://praneethd7.github.io",
        "name": "Praneeth Devunuri Portfolio",
        "description": "Praneeth Devunuri's portfolio website showcasing expertise in Generative AI, Reinforcement Learning, Autonomous Vehicles, and Computer Vision.",
        "publisher": {
          "@id": "https://praneethd7.github.io/#person"
        }
      }
    </script>
  </Fragment>

  <!-- Hero Section -->
  <section class="relative mx-auto max-w-7xl px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28 overflow-visible">
    <!-- Hero-specific glowing backdrops that transition with epsilon -->
    <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-7xl pointer-events-none">
      <!-- Blue/Indigo Glow (Exploitation) -->
      <div id="glow-exploit" class="absolute top-1/4 left-1/4 w-[350px] h-[350px] sm:w-[500px] sm:h-[500px] rounded-full bg-indigo-600/10 blur-[130px] transition-opacity duration-500 opacity-50"></div>
      <!-- Cyan/Gold Glow (Exploration) -->
      <div id="glow-explore" class="absolute top-1/3 right-1/4 w-[350px] h-[350px] sm:w-[500px] sm:h-[500px] rounded-full bg-gradient-to-r from-teal-500/10 to-amber-500/5 blur-[130px] transition-opacity duration-500 opacity-0"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Bio / Description (7 cols) -->
      <div class="lg:col-span-7 flex flex-col items-center lg:items-start text-center lg:text-left">
        
        <h1 class="font-outfit text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-tight">
          Hi, I'm <span class="bg-gradient-to-r from-teal-400 via-indigo-400 to-purple-500 bg-clip-text text-transparent">Praneeth Devunuri</span>
        </h1>

        <!-- Epsilon-Greedy Slider Widget -->
        <div class="w-full max-w-md my-6 p-4 rounded-2xl border border-white/5 bg-slate-900/30 backdrop-blur-md">
          <div class="flex justify-between items-center mb-2">
            <span class="font-outfit text-xs font-semibold uppercase tracking-wider text-slate-400">Policy: Epsilon-Greedy</span>
            <span id="epsilon-val-display" class="font-mono text-sm font-bold text-teal-400">ε = 0.50</span>
          </div>
          
          <div class="relative flex items-center group py-2">
            <input 
              type="range" 
              min="0" 
              max="1" 
              step="0.05" 
              value="0.5" 
              id="epsilon-slider"
              class="w-full h-2 rounded-lg bg-slate-800 appearance-none cursor-pointer accent-teal-400 focus:outline-none transition-all duration-300"
            />
          </div>
          
          <div class="flex justify-between text-[11px] font-mono text-slate-500 mt-2">
            <button id="snap-exploit" class="hover:text-indigo-400 transition-colors cursor-pointer">Exploit (ε=0)</button>
            <button id="snap-balanced" class="hover:text-teal-400 transition-colors cursor-pointer">Balanced (ε=0.5)</button>
            <button id="snap-explore" class="hover:text-brand-cyan transition-colors cursor-pointer">Explore (ε=1)</button>
          </div>
        </div>

        <!-- Sliding Bio Text & Action Buttons -->
        <div class="grid grid-cols-1 w-full min-h-[260px] sm:min-h-[220px]">
          <!-- Exploit state (ε = 0) -->
          <div id="hero-exploit" class="col-start-1 row-start-1 transition-all duration-500 opacity-0 pointer-events-none transform translate-y-2">
            <p class="font-outfit text-xl sm:text-2xl font-semibold text-indigo-400">
              Researcher
            </p>
            <p class="font-inter text-base text-slate-400 max-w-2xl mt-4 leading-relaxed">
              I focus on optimization algorithms, decision processes (MDPs), and agentic workflows to automate complex logistics and scheduling networks. Transitioned from Ph.D. research in Connected and Autonomous Vehicles (UIUC) to driving next-generation AI and optimization systems at Optym.
            </p>
            <div class="flex flex-wrap gap-4 mt-8 justify-center lg:justify-start">
              <a
                href="/publications"
                class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-500 to-blue-600 px-6 py-3 font-outfit text-sm font-semibold text-white shadow-lg shadow-indigo-500/15 hover:shadow-blue-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                Explore Publications
              </a>
              <a
                href="/projects"
                class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-6 py-3 font-outfit text-sm font-semibold text-slate-200 hover:bg-white/10 hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                View Projects
              </a>
            </div>
          </div>

          <!-- Balanced state (ε = 0.5) -->
          <div id="hero-balanced" class="col-start-1 row-start-1 transition-all duration-500 opacity-100 transform translate-y-0">
            <p class="font-outfit text-xl sm:text-2xl font-semibold text-slate-200">
              Senior AI Scientist @ Optym | <span class="text-teal-400 font-mono">ε-Guy</span>
            </p>
            <p class="font-inter text-base text-slate-400 max-w-2xl mt-4 leading-relaxed">
              In reinforcement learning, the epsilon value represents exploration vs exploitation. I embrace this policy by constantly learning and applying complex algorithmic models to optimize networks while exploring the physical world through photography and outdoor trekking.
            </p>
            <div class="flex flex-wrap gap-4 mt-8 justify-center lg:justify-start">
              <a
                href="/publications"
                class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-teal-500 to-indigo-600 px-6 py-3 font-outfit text-sm font-semibold text-white shadow-lg shadow-teal-500/15 hover:shadow-indigo-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                Explore Publications
              </a>
              <a
                href="/projects"
                class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-6 py-3 font-outfit text-sm font-semibold text-slate-200 hover:bg-white/10 hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                View Projects
              </a>
            </div>
          </div>

          <!-- Explore state (ε = 1) -->
          <div id="hero-explore" class="col-start-1 row-start-1 transition-all duration-500 opacity-0 pointer-events-none transform translate-y-2">
            <p class="font-outfit text-xl sm:text-2xl font-semibold text-brand-cyan">
              Creative Explorer & Photographer
            </p>
            <p class="font-inter text-base text-slate-400 max-w-2xl mt-4 leading-relaxed">
              Beyond the codebase, I maximize entropy. I capture landscapes via drone, create graphic designs, and embark on high-altitude treks. Exploring new environments helps me discover novel solutions to both digital and physical challenges.
            </p>
            <div class="flex flex-wrap gap-4 mt-8 justify-center lg:justify-start">
              <a
                href="/photography"
                class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-brand-cyan to-teal-500 px-6 py-3 font-outfit text-sm font-semibold text-slate-950 shadow-lg shadow-brand-cyan/15 hover:shadow-teal-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                View Photography Gallery
              </a>
              <a
                href="/activities"
                class="inline-flex items-center justify-center rounded-xl border border-brand-cyan/20 bg-brand-cyan/5 px-6 py-3 font-outfit text-sm font-semibold text-slate-200 hover:bg-brand-cyan/10 hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                See Hobbies & Leadership
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile Avatar (5 cols) -->
      <div class="lg:col-span-5 flex justify-center relative">
        <!-- Floating Exploitation (Math/AI) Icons -->
        <div id="float-exploit-1" class="absolute top-4 left-6 z-20 pointer-events-none transition-all duration-300 animate-float-1">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-indigo-500/20 bg-slate-950/80 text-sm font-mono font-bold text-indigo-400 shadow-lg shadow-indigo-500/5 backdrop-blur-sm">
            ε
          </div>
        </div>
        <div id="float-exploit-2" class="absolute bottom-12 left-2 z-20 pointer-events-none transition-all duration-300 animate-float-2">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-blue-500/20 bg-slate-950/80 text-sm font-mono font-bold text-blue-400 shadow-lg shadow-blue-500/5 backdrop-blur-sm">
            f(x)
          </div>
        </div>
        <div id="float-exploit-3" class="absolute top-8 right-8 z-20 pointer-events-none transition-all duration-300 animate-float-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-purple-500/20 bg-slate-950/80 text-sm font-mono font-bold text-purple-400 shadow-lg shadow-purple-500/5 backdrop-blur-sm">
            ∑
          </div>
        </div>

        <!-- Floating Software Product building (Balanced) Icons -->
        <div id="float-build-1" class="absolute top-2 left-6 z-20 pointer-events-none transition-all duration-300 animate-float-3 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-teal-500/20 bg-slate-950/80 text-sm text-teal-400 shadow-lg shadow-teal-500/5 backdrop-blur-sm">
            💻
          </div>
        </div>
        <div id="float-build-2" class="absolute bottom-12 right-2 z-20 pointer-events-none transition-all duration-300 animate-float-1 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-indigo-500/20 bg-slate-950/80 text-sm text-indigo-400 shadow-lg shadow-indigo-500/5 backdrop-blur-sm">
            ⚙️
          </div>
        </div>
        <div id="float-build-3" class="absolute top-8 right-8 z-20 pointer-events-none transition-all duration-300 animate-float-4 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-amber-500/20 bg-slate-950/80 text-sm text-amber-400 shadow-lg shadow-amber-500/5 backdrop-blur-sm">
            🚀
          </div>
        </div>

        <!-- Floating Exploration (Hobby/Creative) Icons -->
        <div id="float-explore-1" class="absolute top-0 right-6 z-20 pointer-events-none transition-all duration-300 animate-float-2 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-brand-cyan/20 bg-slate-950/80 text-sm text-brand-cyan shadow-lg shadow-brand-cyan/5 backdrop-blur-sm">
            📷
          </div>
        </div>
        <div id="float-explore-2" class="absolute bottom-8 right-2 z-20 pointer-events-none transition-all duration-300 animate-float-1 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-amber-500/20 bg-slate-950/80 text-sm text-amber-400 shadow-lg shadow-amber-500/5 backdrop-blur-sm">
            🏔️
          </div>
        </div>
        <div id="float-explore-3" class="absolute bottom-4 left-8 z-20 pointer-events-none transition-all duration-300 animate-float-4 opacity-0">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-teal-500/20 bg-slate-950/80 text-sm text-teal-400 shadow-lg shadow-teal-500/5 backdrop-blur-sm">
            🚁
          </div>
        </div>

        <div class="relative group">
          <!-- Outer glowing rings -->
          <div id="avatar-glow-1" class="absolute -inset-0.5 rounded-full bg-gradient-to-r from-teal-400 to-indigo-500 opacity-30 blur-xl group-hover:opacity-60 transition-all duration-500"></div>
          <div id="avatar-glow-2" class="absolute -inset-1 rounded-full bg-gradient-to-r from-purple-500 to-teal-400 opacity-20 blur-2xl group-hover:opacity-40 transition-all duration-500"></div>
          
          <!-- Image container -->
          <div class="relative h-72 w-72 sm:h-80 sm:w-80 overflow-hidden rounded-full border-2 border-white/10 bg-slate-900 shadow-2xl">
            <img
              id="avatar-image"
              src="/assets/pro_pic_new.jpg"
              alt="Praneeth Devunuri"
              class="h-full w-full object-cover object-[center_25%] group-hover:scale-105 transition-all duration-500"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Affiliations Logo Bar -->
  <div class="border-t border-b border-white/5 bg-slate-950/20 py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="font-outfit text-center text-xs font-semibold uppercase tracking-wider text-slate-500 mb-6">
        Professional & Academic Affiliations
      </p>
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-20">
        <div class="flex items-center gap-3.5 group cursor-default">
          <div class="h-12 w-12 flex items-center justify-center rounded-lg bg-white p-2 border border-white/10 group-hover:border-teal-500/30 group-hover:scale-105 transition-all duration-300">
            <img 
              src="/assets/logo_optym.png" 
              alt="Optym" 
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <span class="font-outfit text-sm font-semibold text-slate-300 group-hover:text-white transition-colors duration-300">Optym</span>
        </div>

        <div class="flex items-center gap-3.5 group cursor-default">
          <div class="h-12 w-12 flex items-center justify-center rounded-lg bg-white p-2 border border-white/10 group-hover:border-teal-500/30 group-hover:scale-105 transition-all duration-300">
            <img 
              src="/assets/logo_uiuc.svg" 
              alt="University of Illinois Urbana-Champaign" 
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <span class="font-outfit text-sm font-semibold text-slate-300 group-hover:text-white transition-colors duration-300">UIUC</span>
        </div>
        
        <div class="flex items-center gap-3.5 group cursor-default">
          <div class="h-12 w-12 flex items-center justify-center rounded-lg bg-white p-2 border border-white/10 group-hover:border-teal-500/30 group-hover:scale-105 transition-all duration-300">
            <img 
              src="/assets/logo_tamu.svg" 
              alt="Texas A&M University" 
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <span class="font-outfit text-sm font-semibold text-slate-300 group-hover:text-white transition-colors duration-300">Texas A&M</span>
        </div>
        
        <div class="flex items-center gap-3.5 group cursor-default">
          <div class="h-12 w-12 flex items-center justify-center rounded-lg bg-white p-2 border border-white/10 group-hover:border-teal-500/30 group-hover:scale-105 transition-all duration-300">
            <img 
              src="/assets/logo_iitm.svg" 
              alt="IIT Madras" 
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <span class="font-outfit text-sm font-semibold text-slate-300 group-hover:text-white transition-colors duration-300">IIT Madras</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Core Expertise -->
  <section class="border-t border-white/5 bg-slate-950/40 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-outfit text-3xl sm:text-4xl font-bold tracking-tight text-white">
          Technical Expertise & Core Focus
        </h2>
        <p class="font-inter text-slate-400 max-w-2xl mx-auto mt-4">
          A unique synthesis of theoretical reinforcement learning, computer vision, and hands-on LLM engineering.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
        {skills.map((skill) => (
          <div class="relative rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm hover:border-teal-500/30 transition-colors duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-900 border border-white/10" set:html={skill.icon} />
              <h3 class="font-outfit text-lg font-bold text-slate-200">{skill.category}</h3>
            </div>
            <ul class="space-y-3">
              {skill.items.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-400">
                  <svg class="h-5 w-5 text-teal-400/80 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured AI Projects -->
  <section class="border-t border-white/5 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-12">
        <div>
          <h2 class="font-outfit text-3xl font-bold tracking-tight text-white text-center sm:text-left">
            Featured Generative AI Work
          </h2>
          <p class="font-inter text-slate-400 mt-2 text-center sm:text-left">
            Showcasing current projects built in the LLM and multi-agent space.
          </p>
        </div>
        <a
          href="/projects"
          class="inline-flex items-center gap-1.5 font-outfit text-sm font-semibold text-teal-400 hover:text-teal-300 transition-colors group"
        >
          View All Projects
          <svg class="h-4 w-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredProjects.map((project) => (
          <div class="flex flex-col rounded-2xl border border-white/10 bg-slate-900/40 p-6 backdrop-blur-sm hover:border-indigo-500/30 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:shadow-indigo-500/5">
