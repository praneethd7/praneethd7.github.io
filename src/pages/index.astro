  <!-- Client-side script for interactive copy functionality -->
  <script>
    function setupContactSection() {
      const copyBtn = document.getElementById('copy-email-btn');
      const emailEl = document.getElementById('email-address');
      const copyIcon = document.getElementById('copy-icon');
      const checkIcon = document.getElementById('check-icon');
      const btnText = document.getElementById('copy-btn-text');

      if (copyBtn && emailEl && copyIcon && checkIcon && btnText) {
        copyBtn.addEventListener('click', async () => {
          try {
            const email = emailEl.textContent?.trim() || 'devunurisaipraneeth@gmail.com';
            await navigator.clipboard.writeText(email);
            
            // Show check state
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            btnText.textContent = 'Copied!';
            copyBtn.classList.add('border-emerald-500/50', 'text-emerald-400', 'bg-emerald-500/10');
            copyBtn.classList.remove('hover:border-teal-400/50', 'hover:text-teal-400', 'hover:bg-teal-500/10');

            // Reset after 2 seconds
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
              btnText.textContent = 'Copy';
              copyBtn.classList.remove('border-emerald-500/50', 'text-emerald-400', 'bg-emerald-500/10');
              copyBtn.classList.add('hover:border-teal-400/50', 'hover:text-teal-400', 'hover:bg-teal-500/10');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy email address: ', err);
          }
        });
      }
    }

    // Run on page load and on View Transitions
    setupContactSection();
    document.addEventListener('astro:after-swap', setupContactSection);
  </script>

  <!-- Client-side script for Epsilon-Greedy Slider Logic -->
  <script>
    function setupEpsilonSlider() {
      const slider = document.getElementById('epsilon-slider') as HTMLInputElement | null;
      const valDisplay = document.getElementById('epsilon-val-display');
      
      const snapExploit = document.getElementById('snap-exploit');
      const snapBalanced = document.getElementById('snap-balanced');
      const snapExplore = document.getElementById('snap-explore');

      const glowExploit = document.getElementById('glow-exploit');
      const glowExplore = document.getElementById('glow-explore');

      const ring1 = document.getElementById('avatar-glow-1');
      const ring2 = document.getElementById('avatar-glow-2');

      const floatExploit = [
        document.getElementById('float-exploit-1'),
        document.getElementById('float-exploit-2'),
        document.getElementById('float-exploit-3')
      ];
      const floatBuild = [
        document.getElementById('float-build-1'),
        document.getElementById('float-build-2'),
        document.getElementById('float-build-3')
      ];
      const floatExplore = [
        document.getElementById('float-explore-1'),
        document.getElementById('float-explore-2'),
        document.getElementById('float-explore-3')
      ];

      if (!slider) return;

      function setElementState(id: string, opacity: number) {
        const el = document.getElementById(id);
        if (el) {
          el.style.opacity = opacity.toString();
          if (opacity > 0.1) {
            el.style.pointerEvents = 'auto';
            el.style.transform = 'translateY(0px)';
          } else {
            el.style.pointerEvents = 'none';
            el.style.transform = 'translateY(8px)';
          }
        }
      }

      function updateEpsilon() {
        if (!slider) return;
        const val = parseFloat(slider.value);
        if (valDisplay) {
          valDisplay.textContent = `ε = ${val.toFixed(2)}`;
        }

        // Determine discrete active state
        let activeState = 'balanced';
        if (val < 0.25) {
          activeState = 'exploit';
        } else if (val > 0.75) {
          activeState = 'explore';
        }

        // Apply opacities strictly to active text blocks to prevent overlapping
        setElementState('hero-exploit', activeState === 'exploit' ? 1 : 0);
        setElementState('hero-balanced', activeState === 'balanced' ? 1 : 0);
        setElementState('hero-explore', activeState === 'explore' ? 1 : 0);

        // Apply opacities to float icons based on state
        const showExploitIcons = activeState === 'exploit';
        floatExploit.forEach(el => {
          if (el) {
            el.style.opacity = showExploitIcons ? '1' : '0';
            el.style.transform = showExploitIcons ? 'scale(1)' : 'scale(0.7)';
          }
        });

        const showBuildIcons = activeState === 'balanced';
        floatBuild.forEach(el => {
          if (el) {
            el.style.opacity = showBuildIcons ? '1' : '0';
            el.style.transform = showBuildIcons ? 'scale(1)' : 'scale(0.7)';
          }
        });

        const showExploreIcons = activeState === 'explore';
        floatExplore.forEach(el => {
          if (el) {
            el.style.opacity = showExploreIcons ? '1' : '0';
            el.style.transform = showExploreIcons ? 'scale(1)' : 'scale(0.7)';
          }
        });

        // Glow effects
        if (glowExploit) {
          glowExploit.style.opacity = (activeState === 'exploit' || activeState === 'balanced') ? '0.5' : '0';
        }
        if (glowExplore) {
          glowExplore.style.opacity = (activeState === 'explore') ? '0.5' : '0';
        }

        // Slider track styling
        const percentage = val * 100;
        slider.style.background = `linear-gradient(to right, #0DFFC6 0%, #6366F1 ${percentage}%, #1e293b ${percentage}%, #1e293b 100%)`;

        // Ring animations/gradients
        if (ring1 && ring2) {
          if (activeState === 'exploit') {
            ring1.style.background = 'linear-gradient(to right, #6366F1, #3B82F6)';
            ring2.style.background = 'linear-gradient(to right, #3B82F6, #1D4ED8)';
            ring1.style.animation = 'none';
            ring2.style.animation = 'none';
          } else if (activeState === 'explore') {
            ring1.style.background = 'linear-gradient(to right, #0DFFC6, #D946EF, #F59E0B)';
            ring2.style.background = 'linear-gradient(to right, #F59E0B, #0DFFC6, #D946EF)';
            ring1.style.animation = 'spin-slow 6s linear infinite';
            ring2.style.animation = 'spin-slow 8s linear infinite reverse';
          } else {
            ring1.style.background = 'linear-gradient(to right, #0DFFC6, #6366F1)';
            ring2.style.background = 'linear-gradient(to right, #6366F1, #0DFFC6)';
            ring1.style.animation = 'none';
            ring2.style.animation = 'none';
          }
        }
      }

      slider.addEventListener('input', updateEpsilon);

      // Snap buttons listeners
      if (snapExploit) {
        snapExploit.addEventListener('click', () => {
          slider.value = '0';
          updateEpsilon();
        });
      }
      if (snapBalanced) {
        snapBalanced.addEventListener('click', () => {
          slider.value = '0.5';
          updateEpsilon();
        });
      }
      if (snapExplore) {
        snapExplore.addEventListener('click', () => {
          slider.value = '1';
          updateEpsilon();
        });
      }

      // Initial update
      updateEpsilon();
    }

    setupEpsilonSlider();
    document.addEventListener('astro:after-swap', setupEpsilonSlider);
  </script>

  <!-- CSS Styles for custom animations and elements -->
  <style>
    @keyframes float-up-down {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-8px) rotate(3deg); }
    }
    @keyframes float-down-up {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(8px) rotate(-3deg); }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    
    .animate-float-1 {
      animation: float-up-down 4s ease-in-out infinite;
    }
    .animate-float-2 {
      animation: float-down-up 4.5s ease-in-out infinite;
    }
    .animate-float-3 {
      animation: float-up-down 5s ease-in-out infinite 0.5s;
    }
    .animate-float-4 {
      animation: float-down-up 5.5s ease-in-out infinite 1s;
    }
    
    /* Custom thumb styling for range input */
    #epsilon-slider::-webkit-slider-thumb {
      appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 9999px;
      background: #0DFFC6;
      border: 3px solid #020617;
      box-shadow: 0 0 10px rgba(13, 255, 198, 0.8);
      cursor: pointer;
      transition: transform 0.15s ease, background-color 0.15s ease;
    }
    #epsilon-slider::-webkit-slider-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 15px rgba(13, 255, 198, 1);
    }
    #epsilon-slider::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 9999px;
      background: #0DFFC6;
      border: 3px solid #020617;
      box-shadow: 0 0 10px rgba(13, 255, 198, 0.8);
      cursor: pointer;
      transition: transform 0.15s ease, background-color 0.15s ease;
    }
    #epsilon-slider::-moz-range-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 15px rgba(13, 255, 198, 1);
    }
  </style>
