---
import Layout from '../layouts/Layout.astro';

const publications = [
  {
    title: "TransitGPT: A Generative AI-based framework for interacting with GTFS data using Large Language Models",
    authors: "Saipraneeth Devunuri, Lewis Lehe",
    venue: "Public Transport (Journal)",
    year: "2025",
    category: "Generative AI",
    tags: ["LLMs", "Generative AI", "GTFS", "NLP"],
    citations: "15+",
    paperUrl: "https://arxiv.org/abs/2412.06831",
    codeUrl: "https://github.com/UTEL-UIUC/TransitGPT"
  },
  {
    title: "A Pipeline and NIR-Enhanced Dataset for Parking Lot Segmentation",
    authors: "Saipraneeth Devunuri, et al.",
    venue: "IEEE/CVF Winter Conference on Applications of Computer Vision (WACV)",
    year: "2025",
    category: "Computer Vision",
    tags: ["Computer Vision", "Deep Learning", "Segmentation"],
    citations: "5+",
    paperUrl: "https://openaccess.thecvf.com/content/WACV2025/html/Devunuri_A_Pipeline_and_NIR-Enhanced_Dataset_for_Parking_Lot_Segmentation_WACV_2025_paper.html",
    codeUrl: ""
  },
  {
    title: "ChatGPT for GTFS: Benchmarking LLMs on GTFS Semantics and Retrieval",
    authors: "Saipraneeth Devunuri, Lewis Lehe",
    venue: "Public Transport (Journal)",
    year: "2024",
    category: "Generative AI",
    tags: ["LLMs", "Benchmarking", "GTFS", "Prompt Engineering"],
    citations: "45+",
    paperUrl: "https://arxiv.org/abs/2308.02618",
    codeUrl: ""
  },
  {
    title: "GTFS Segments: A Fast and Efficient Library to Generate Bus Stop Spacings",
    authors: "Saipraneeth Devunuri, Lewis Lehe",
    venue: "The Journal of Open Source Software",
    year: "2024",
    category: "Transportation Systems",
    tags: ["Software Library", "GTFS", "GIS", "Python"],
    citations: "12+",
    paperUrl: "https://doi.org/10.21105/joss.06014",
    codeUrl: "https://github.com/saipraneethd/gtfs_segments"
  },
  {
    title: "Bus Stop Spacings Statistics: Theory and Evidence",
    authors: "Lewis Lehe, Saipraneeth Devunuri",
    venue: "Journal of Public Transportation",
    year: "2024",
    category: "Transportation Systems",
    tags: ["GTFS", "Public Transit", "Statistics"],
    citations: "30+",
    paperUrl: "https://arxiv.org/abs/2208.04394",
    codeUrl: ""
  },
  {
    title: "A Survey of Errors in GTFS Static Feeds from the United States",
    authors: "Saipraneeth Devunuri, Lewis Lehe",
    venue: "Transport Findings",
    year: "2024",
    category: "Transportation Systems",
    tags: ["Data Quality", "GTFS", "Public Transit"],
    citations: "8+",
    paperUrl: "https://doi.org/10.32866/001c.116805",
    codeUrl: ""
  },
  {
    title: "Scale Effects in Ridesplitting: A Case Study of the City of Chicago",
    authors: "Saipraneeth Devunuri, Alireza Talebpour",
    venue: "Transportation Research Part A: Policy and Practice",
    year: "2023",
    category: "Transportation Systems",
    tags: ["Ridesharing", "Economics", "Simulation"],
    citations: "55+",
    paperUrl: "https://arxiv.org/abs/2209.04944",
    codeUrl: ""
  }
];

const categories = ['All', 'Generative AI', 'Transportation Systems', 'Computer Vision'];
---

<Layout title="Publications | Saipraneeth Devunuri" description="Peer-reviewed journal articles, conference papers, and academic publications by Saipraneeth Devunuri in Generative AI, Intelligent Transportation Systems, and Computer Vision.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    
    <!-- Title Area -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="font-outfit text-4xl sm:text-5xl font-extrabold tracking-tight text-white">
        Academic Publications
      </h1>
      <p class="font-inter text-slate-400 mt-4 leading-relaxed">
        Research at the intersection of machine learning, public transit economics, and generative models. Follow links below to read preprint PDFs or access open-source code repositories.
      </p>
    </div>

    <!-- Overview Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 mb-12">
      <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-5 backdrop-blur-sm text-center">
        <span class="block font-outfit text-3xl font-extrabold text-teal-400">280+</span>
        <span class="block font-inter text-xs text-slate-400 mt-1 uppercase tracking-wider">Total Citations</span>
      </div>
      <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-5 backdrop-blur-sm text-center">
        <span class="block font-outfit text-3xl font-extrabold text-indigo-400">8</span>
        <span class="block font-inter text-xs text-slate-400 mt-1 uppercase tracking-wider">h-index</span>
      </div>
      <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-5 backdrop-blur-sm text-center">
        <span class="block font-outfit text-3xl font-extrabold text-purple-400">7</span>
        <span class="block font-inter text-xs text-slate-400 mt-1 uppercase tracking-wider">Core Papers</span>
      </div>
      <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-5 backdrop-blur-sm text-center">
        <span class="block font-outfit text-3xl font-extrabold text-amber-400">2</span>
        <span class="block font-inter text-xs text-slate-400 mt-1 uppercase tracking-wider">OS Libraries</span>
      </div>
    </div>

    <!-- Search & Filters Container -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-12">
      <!-- Search Input -->
      <div class="relative w-full md:max-w-md">
        <input
          type="text"
          id="pub-search"
          placeholder="Search papers by title or tags..."
          class="w-full rounded-xl border border-white/10 bg-slate-900/60 py-3 pl-11 pr-4 font-inter text-sm text-slate-100 placeholder-slate-500 focus:border-teal-500 focus:outline-none focus:ring-1 focus:ring-teal-500 transition-all duration-300"
        />
        <svg class="absolute left-4 top-3.5 h-4.5 w-4.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <!-- Categories filters -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        {categories.map((category) => (
          <button
            class={`pub-filter-btn font-outfit text-xs sm:text-sm font-semibold px-4 py-2 rounded-xl transition-all duration-300 ${
              category === 'All'
                ? 'bg-teal-500 text-white shadow-lg shadow-teal-500/10'
                : 'bg-white/5 text-slate-400 hover:bg-white/10 hover:text-slate-200'
            }`}
            data-filter={category.toLowerCase()}
          >
            {category}
          </button>
        ))}
      </div>
    </div>

    <!-- Publications List -->
    <div class="space-y-6">
      {publications.map((pub) => (
        <div
          class="pub-card flex flex-col md:flex-row gap-6 items-start rounded-2xl border border-white/10 bg-slate-900/20 p-6 backdrop-blur-sm hover:border-slate-800 transition-all duration-300"
          data-category={pub.category.toLowerCase()}
          data-title={pub.title.toLowerCase()}
          data-tags={pub.tags.join(' ').toLowerCase()}
        >
          <!-- Citations / Year Badge -->
          <div class="flex md:flex-col items-center justify-center shrink-0 w-full md:w-24 gap-2 border-b md:border-b-0 md:border-r border-white/5 pb-4 md:pb-0 md:pr-6 text-center">
            <span class="font-outfit text-2xl font-black text-slate-100">{pub.year}</span>
            <div class="rounded-lg bg-teal-500/5 border border-teal-500/20 px-2.5 py-1 text-[10px] font-bold text-teal-400 uppercase tracking-widest">
              Cites: {pub.citations}
            </div>
          </div>

          <!-- Publication Information -->
          <div class="flex-grow">
            <span class="inline-flex rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-[10px] font-semibold text-indigo-400 border border-indigo-500/20 mb-3 uppercase tracking-wider">
              {pub.category}
            </span>
            <h2 class="font-outfit text-lg sm:text-xl font-bold text-white leading-snug">{pub.title}</h2>
            <p class="font-inter text-sm text-slate-300 mt-2">{pub.authors}</p>
            <p class="font-inter text-xs text-slate-500 italic mt-1">{pub.venue}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mt-4">
              {pub.tags.map((tag) => (
                <span class="text-[10px] font-medium px-2 py-0.5 rounded bg-white/5 text-slate-400 border border-white/5">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Links -->
          <div class="flex sm:flex-col gap-3 shrink-0 w-full sm:w-auto mt-4 sm:mt-0 pt-4 sm:pt-0 border-t sm:border-t-0 border-white/5">
            {pub.paperUrl && (
              <a
                href={pub.paperUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/5 px-4 py-2 font-outfit text-xs font-semibold text-slate-200 hover:bg-white/10 hover:text-white transition-all w-full sm:w-28 text-center"
              >
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                PDF
              </a>
            )}
            {pub.codeUrl && (
              <a
                href={pub.codeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-1.5 rounded-lg bg-teal-500/10 border border-teal-500/20 px-4 py-2 font-outfit text-xs font-semibold text-teal-400 hover:bg-teal-500/20 transition-all w-full sm:w-28 text-center"
              >
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.193 22 16.44 22 12.017 22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                Code
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<script>
  function setupPubFilters() {
    const buttons = document.querySelectorAll('.pub-filter-btn');
    const cards = document.querySelectorAll('.pub-card');
    const searchInput = document.getElementById('pub-search') as HTMLInputElement;

    let activeFilter = 'all';
    let searchQuery = '';

    function filterPublications() {
      cards.forEach((card) => {
        const category = card.getAttribute('data-category') || '';
        const title = card.getAttribute('data-title') || '';
        const tags = card.getAttribute('data-tags') || '';
        
        const matchesCategory = activeFilter === 'all' || category === activeFilter;
        const matchesSearch = title.includes(searchQuery) || tags.includes(searchQuery);

        if (matchesCategory && matchesSearch) {
          (card as HTMLElement).style.display = 'flex';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.classList.remove('bg-teal-500', 'text-white', 'shadow-lg', 'shadow-teal-500/10');
          b.classList.add('bg-white/5', 'text-slate-400', 'hover:bg-white/10', 'hover:text-slate-200');
        });
        btn.classList.remove('bg-white/5', 'text-slate-400', 'hover:bg-white/10', 'hover:text-slate-200');
        btn.classList.add('bg-teal-500', 'text-white', 'shadow-lg', 'shadow-teal-500/10');

        activeFilter = btn.getAttribute('data-filter') || 'all';
        filterPublications();
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        filterPublications();
      });
    }
  }

  // Initial setup and transitions compatibility
  setupPubFilters();
  document.addEventListener('astro:after-swap', setupPubFilters);
</script>
