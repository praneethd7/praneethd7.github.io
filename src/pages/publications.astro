                class="copy-bibtex-btn absolute right-3 top-3 px-2.5 py-1 rounded bg-white/5 hover:bg-white/10 text-slate-400 hover:text-slate-200 border border-white/5 transition-colors text-[10px] font-sans font-semibold flex items-center gap-1 cursor-pointer"
