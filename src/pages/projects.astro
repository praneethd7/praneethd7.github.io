---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const projects = await getCollection('projects');

const typeOrder = { 'current': 1, 'previous': 2, 'course': 3 };
projects.sort((a, b) => {
  if (typeOrder[a.data.type] !== typeOrder[b.data.type]) {
    return typeOrder[a.data.type] - typeOrder[b.data.type];
  }
  return a.data.order - b.data.order;
});

const projectsWithContent = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await render(project);
    return { project, Content };
  })
);

const categories = ['All', 'Generative AI', 'Reinforcement Learning', 'Autonomous Vehicles', 'Computer Vision', 'Other'];
---

<Layout title="Projects | Praneeth Devunuri" description=" Praneeth Devunuri's engineering and research projects, spanning Generative AI, Reinforcement Learning, Autonomous Vehicles, and Computer Vision.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": projects.map((p) => ({
        "@type": "CreativeWork",
        "@id": `https://praneethd7.github.io/projects/#project-${p.id}`,
        "name": p.data.title,
        "keywords": p.data.tags.join(', '),
        "genre": p.data.category,
        "creator": {
          "@id": "https://praneethd7.github.io/#person"
        }
      }))
    })} />
  </Fragment>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    
    <!-- Title Area -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h1 class="font-outfit text-4xl sm:text-5xl font-extrabold tracking-tight text-white">
        Projects & Research
      </h1>
      <p class="font-inter text-slate-400 mt-4 leading-relaxed">
        A catalog of my professional work in Generative AI along with my previous PhD research and academic achievements. Use the filters below to browse by domain.
      </p>
    </div>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-12">
      {categories.map((category) => (
        <button
          class={`filter-btn font-outfit text-sm font-semibold px-4.5 py-2 rounded-xl transition-all duration-300 ${
            category === 'All'
              ? 'bg-teal-500 text-white shadow-lg shadow-teal-500/10'
              : 'bg-white/5 text-slate-400 hover:bg-white/10 hover:text-slate-200'
          }`}
          data-filter={category.toLowerCase()}
        >
          {category}
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 gap-10">
      {projectsWithContent.map(({ project, Content }) => (
        <div
          class="project-card flex flex-col rounded-2xl border border-white/10 bg-slate-900/40 p-6 sm:p-8 backdrop-blur-sm transition-all duration-500 hover:border-slate-700/50"
          data-category={project.data.category.toLowerCase()}
        >
          <!-- Header metadata -->
          <div class="flex flex-wrap items-center justify-between gap-4 border-b border-white/5 pb-4 mb-6">
            <div class="flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-teal-500/10 px-3 py-1 text-xs font-semibold text-teal-400 border border-teal-500/20">
                {project.data.category}
              </span>
              {project.data.type === 'current' && (
                <span class="rounded-full bg-indigo-500/10 px-3 py-1 text-xs font-semibold text-indigo-400 border border-indigo-500/20">
                  Featured / Current
                </span>
              )}
            </div>
            {project.data.guide && (
              <span class="font-inter text-xs text-slate-400 italic">
                Guide: {project.data.guide}
              </span>
            )}
          </div>

          <!-- Main Info -->
          <div class="flex-grow">
            <h2 class="font-outfit text-2xl font-bold text-white tracking-tight">{project.data.title}</h2>
            
            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mt-3 mb-6">
              {project.data.tags.map((tag) => (
                <span class="text-xs font-medium px-2.5 py-0.5 rounded bg-white/5 text-slate-300 border border-white/5">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Markdown Content Rendered -->
            <article class="prose prose-invert max-w-none text-slate-300 leading-relaxed text-sm sm:text-base space-y-4">
              <Content />
            </article>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<script>
  function setupFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Toggle Active Button Styles
        buttons.forEach((b) => {
          b.classList.remove('bg-teal-500', 'text-white', 'shadow-lg', 'shadow-teal-500/10');
          b.classList.add('bg-white/5', 'text-slate-400', 'hover:bg-white/10', 'hover:text-slate-200');
        });
        btn.classList.remove('bg-white/5', 'text-slate-400', 'hover:bg-white/10', 'hover:text-slate-200');
        btn.classList.add('bg-teal-500', 'text-white', 'shadow-lg', 'shadow-teal-500/10');

        const filter = btn.getAttribute('data-filter');

        cards.forEach((card) => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            card.classList.remove('hidden');
            // Subtle fade-in animation
            card.animate(
              [
                { opacity: 0, transform: 'translateY(10px)' },
                { opacity: 1, transform: 'translateY(0)' }
              ],
              { duration: 300, easing: 'ease-out' }
            );
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  }

  // Setup on page load and swap
  setupFilters();
  document.addEventListener('astro:after-swap', setupFilters);
</script>
